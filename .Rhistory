#name
pkg.name <- "tmbExtract"
#directory
(pkg.dir <- path.expand("~/Documents/PhD_Jemay"))
#file to the package
(path.to.pkg <- file.path(pkg.dir, pkg.name))
dir.create(path=file.path(path.to.pkg, "misc"))
(ignore.file <- file.path(path.to.pkg, ".Rbuildignore"))
if(! require("devtools"))
install.packages(pkgs="devtools")
if(! require("roxygen2"))
install.packages(pkgs="roxygen2")
if(! require("testthat"))
install.packages(pkgs="testthat")
## Packages loading
suppressPackageStartupMessages(library("devtools"))
suppressPackageStartupMessages(library("roxygen2"))
suppressPackageStartupMessages(library("testthat"))
if(! require("Rcpp"))
install.packages(pkgs="Rcpp")
# #directory
setwd("~/Documents/PhD_Jemay/")
#name
pkg.name <- "tmbExtract"
#directory
(pkg.dir <- path.expand("~/Documents/PhD_Jemay"))
#file to the package
(path.to.pkg <- file.path(pkg.dir, pkg.name))
#List of fields
pkg.fields <- list()
#name
pkg.fields[["Package"]] <- pkg.name
#version
pkg.fields[["Version"]] <- "0.1.0"
## Titre
## default: "What the Package Does (One Line, Title Case)"
pkg.fields[["Title"]] <- "Extract TMB parameters "
#Description
## default: "What the package does (one paragraph)."
pkg.fields[["Description"]] <- "Extract TMB parameters from a list containing TMB::MakeADFun and nlminb objects."
#Auteur
## default: "person(\"First\", \"Last\", , \"first.last@example.com\",
##                  c(\"aut\", \"cre\"), comment = c(ORCID = \"YOUR-ORCID-ID\"))"
pkg.fields[["Authors@R"]] <- paste("person(\"Jemay\",",
"\"Salomon\",",
",",
"\"jemay.salomon@inrae.fr\",",
"c(\"aut\", \"cre\"),",
"comment = c(ORCID = \"0000-0003-4454-7916\"))")
## default: "What license it uses"
pkg.fields[["License"]] <- "MIT"
setwd(path.to.pkg)
usethis::use_mit_license("Jemay SALOMON")
usethis::use_citation()
# Add a dependency
usethis::use_package("TMB")
# (Re-)build NAMESPACE
document()
# Reload the package: CTRL-L or
load_all()
usethis::use_import_from("TMB", sdreport)
devtools::document(pkg=path.to.pkg)
built.pkg <- devtools::build(pkg=path.to.pkg)
devtools::check(pkg=path.to.pkg)
devtools::install_local(path=built.pkg)
